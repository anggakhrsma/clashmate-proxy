# Network
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# Proxy authentication
# Clients can send the shared secret via x-clashmate-client-secret, x-client-secret,
# or Authorization: Bearer <secret>. Admin routes use the admin secret similarly.
CLIENT_API_SECRET=replace-with-a-long-random-client-secret
ADMIN_API_SECRET=replace-with-a-different-long-random-admin-secret

# Storage
SQLITE_PATH=./data/clashmate-proxy.sqlite

# Proxy behavior
CACHE_TTL_SECONDS=10
VALIDATION_SWEEP_INTERVAL_MINUTES=15
UPSTREAM_BASE_URL=https://api.clashofclans.com/v1
UPSTREAM_TIMEOUT_MS=10000
UPSTREAM_MAX_RETRIES=2
KEY_UNHEALTHY_COOLDOWN_SECONDS=60
ACCOUNT_UNHEALTHY_COOLDOWN_SECONDS=300

# Managed Clash developer portal keys
# Use the static outbound IP/CIDR exposed by your Pterodactyl host.
COC_MANAGED_KEY_ALLOWED_CIDRS=203.0.113.10/32
COC_MANAGED_KEY_NAME_PREFIX=clashmate-proxy
COC_MANAGED_KEY_DESCRIPTION=Managed by clashmate-proxy
# Optional: comma-separated portal scopes. Leave blank to use the portal default/full access.
COC_MANAGED_KEY_SCOPES=

# Clash of Clans developer accounts
# Provide at least one full email/password pair.
COC_ACCOUNT_1_EMAIL=developer1@example.com
COC_ACCOUNT_1_PASSWORD=replace-with-password-1
COC_ACCOUNT_2_EMAIL=
COC_ACCOUNT_2_PASSWORD=
COC_ACCOUNT_3_EMAIL=
COC_ACCOUNT_3_PASSWORD=
COC_ACCOUNT_4_EMAIL=
COC_ACCOUNT_4_PASSWORD=
COC_ACCOUNT_5_EMAIL=
COC_ACCOUNT_5_PASSWORD=
COC_ACCOUNT_6_EMAIL=
COC_ACCOUNT_6_PASSWORD=
COC_ACCOUNT_7_EMAIL=
COC_ACCOUNT_7_PASSWORD=
COC_ACCOUNT_8_EMAIL=
COC_ACCOUNT_8_PASSWORD=
COC_ACCOUNT_9_EMAIL=
COC_ACCOUNT_9_PASSWORD=
COC_ACCOUNT_10_EMAIL=
COC_ACCOUNT_10_PASSWORD=
